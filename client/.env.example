VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_DELIVERY_PINCODES=509208

# Production only (Vercel): your Render backend URL, no trailing slash
# VITE_API_URL=https://farm2home-api.onrender.com

# Google sign-in — enable Google provider in Firebase Console → Authentication
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# VITE_USE_GOOGLE_PLACES=true

# Farm location for delivery route map (defaults: Madurai area)
VITE_FARM_LAT=9.9252
VITE_FARM_LNG=78.1198
VITE_FARM_NAME=Farm2Home
