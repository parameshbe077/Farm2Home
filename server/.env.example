# Option A: path to service account JSON (Firebase download name is usually *-firebase-adminsdk-*.json)

FIREBASE_SERVICE_ACCOUNT_PATH=./farm2home-759a4-firebase-adminsdk-fbsvc-a0e60fd028.json



# Comma-separated admin emails (must match Firebase Auth users)

ADMIN_EMAILS=your-admin@email.com



# Order alert emails (defaults to ADMIN_EMAILS if not set)

ORDER_ALERT_EMAILS=your-admin@email.com



# SMTP for order alert emails (Gmail example below)

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_SECURE=false

SMTP_USER=your-email@gmail.com

SMTP_PASS=your-gmail-app-password



PORT=5000

