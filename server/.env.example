# Firebase (Firestore + Storage for product photos)
FIREBASE_SERVICE_ACCOUNT_PATH=./your-firebase-adminsdk.json
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app



# Comma-separated admin emails (must match Firebase Auth users)

ADMIN_EMAILS=your-admin@email.com



# Order alert emails (defaults to ADMIN_EMAILS if not set)

ORDER_ALERT_EMAILS=your-admin@email.com



# SMTP for order alert emails (Gmail example below)

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_SECURE=false

SMTP_USER=your-email@gmail.com

SMTP_PASS=your-gmail-app-password



PORT=5000

# Production (Render): comma-separated Vercel frontend URL(s) for CORS
# CLIENT_URL=https://farm2home.vercel.app,https://www.yourdomain.com

# Delivery serviceable pincodes (comma-separated)
DELIVERY_PINCODES=509208

# Google Geocoding API (server — pin drag / address lookup)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

